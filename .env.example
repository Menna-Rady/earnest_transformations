# Airflow
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# These may alternatively be created in Airflow's Admin > Connections screen:
# kafka_default, snowflake_default, and azure_data_lake_default.

# Kafka (external service)
KAFKA_SERVER=kafka.example.com:9092
KAFKA_TOPIC=products
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISMS=PLAIN

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_URL=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=SYSADMIN

# Azure Data Lake / Iceberg connection boundary
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
BRONZE_LAYER_PATH=abfss://lake@account.dfs.core.windows.net/bronze
SILVER_LAYER_PATH=abfss://lake@account.dfs.core.windows.net/silver
GOLD_LAYER_PATH=abfss://lake@account.dfs.core.windows.net/gold
LAKEHOUSE_WAREHOUSE=abfss://lake@account.dfs.core.windows.net/warehouse
LAKEHOUSE_CATALOG=lakehouse

# Optional serving endpoints
FASTAPI_HEALTH_URL=http://fastapi:8000/health
SUPERSET_HEALTH_URL=http://superset:8088/health
DUCKDB_PATH=/opt/earnest/data/analytics.duckdb

# Optional enrichment and alerting
GROQ_API_KEY=
HOLIDAY_API_KEY=
DISCORD_WEBHOOK_URL=
LOG_LEVEL=INFO
